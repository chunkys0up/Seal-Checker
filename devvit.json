{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "seal-checker",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit"
  },
  "scheduler": {
    "tasks": {
      "timeLimitScheduler": {
        "endpoint": "/internal/scheduler/one-off-source-time-limit"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator",
      "asUser": ["SUBMIT_COMMENT"]
    },
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["generativelanguage.googleapis.com"]
    }
  },
  "dev": {
    "subreddit": "seal_checker_dev"
  },
  "settings": {
    "subreddit": {
      "aiEnabled": {
        "type": "boolean",
        "label": "Use gemini to check if post title matches the article (clickbait/misinformation detection). If labeled as clickbait then user can be reported",
        "defaultValue": false
      },
      "geminiApiKey": {
        "type": "string",
        "label": "Gemini Api Key",
        "defaultValue": ""
      },
      "timeLimit": {
        "type": "number",
        "label": "Timer(minutes) for flagged post to post url source",
        "validationEndpoint": "/internal/settings/validate-time",
        "defaultValue": 60
      },
      "urlFlairs": {
        "type": "string",
        "label": "Flairs that require a url, Ex input: Research post, flair1, blog",
        "validationEndpoint": "/internal/settings/validate-flair",
        "defaultValue": ""
      },
      "actionOnExpiry": {
        "type": "string",
        "label": "Bot actions if poster doesn't provide url sources in time limit. Possible actions: lock, delete, report",
        "validationEndpoint": "/internal/settings/validate-action",
        "defaultValue": "lock"
      }
    }
  }
}
