{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "seal-checker",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Mop comments",
        "description": "Remove this comment and all child comments. This might take a few seconds to run.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-comment"
      },
      {
        "label": "Mop post comments",
        "description": "Remove all comments of this post. This might take a few seconds to run.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-post"
      }
    ]
  },
  "forms": {
    "mopComment": "/internal/form/mop-comment-submit",
    "mopPost": "/internal/form/mop-post-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": true
  },
  "dev": {
    "subreddit": "seal_checker_dev"
  },
  "settings": {
      "subreddit": {
          "timeLimit": {
              "type": "number",
              "label": "Timer(minutes) for flagged post to post url source",
              "defaultValue": 60
          },
          "exemptFlairs": {
              "type": "string",
              "label": "Exempt tags from the bot, Ex input: Research post, flair1, blog",
              "defaultValue": ""
          },
          "actionOnExpiry": {
              "type": "string",
              "label": "Bot actions if poster doesn't provide url sources in time limit. Possible actions: lock, delete, report",
              "defaultValue": "lock"
          }
      }
  }
}
